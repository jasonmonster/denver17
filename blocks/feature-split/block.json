{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "denver17/feature-split",
  "title": "Feature Split",
  "category": "denver17",
  "description": "Two-column section: image on one side, text on the other. Use once for the bar, once for the community section.",
  "supports": { "html": false, "className": false, "anchor": false },
  "attributes": {
    "tag":      { "type": "string", "default": "" },
    "heading":  { "type": "string", "default": "" },
    "body":     { "type": "string", "default": "" },
    "linkText": { "type": "string", "default": "" },
    "linkUrl":  { "type": "string", "default": "" },
    "image":    { "type": "object", "default": {} },
    "variant":  { "type": "string", "default": "dark", "enum": ["dark", "mid"] },
    "layout":   { "type": "string", "default": "image-left", "enum": ["image-left", "text-left"] }
  }
}
